%nav.bg-zinc-950.text-zinc-50{ class: navbar_classes }
  .flex.md:justify-between.w-full.items-center.relative.min-h-8
    .block.sm:hidden
      %button#mobile-menu-button{ class: mobile_button_classes }
        ☰

    - if @title[:text].present? || @left_items.present?
      .flex.items-center.absolute.transform{ class: 'left-1/2 -translate-x-1/2 md:left-auto md:translate-x-0' }
        - if @title[:text].present?
          = link_to @title[:link] do
            .truncate{ class: title_classes }
              = @title[:text]
        - if @left_items.present?
          %ul.flex-row.items-center.space-x-4.ml-4.hidden.md:flex
            - @left_items.each do |item|
              = item

  - if @right_items.present?
    %ul.items-center.space-x-4.hidden.md:flex
      - @right_items.each do |item|
        = item

#mobile-menu{ class: mobile_menu_classes }
  - if @left_items.present?
    %ul.flex.flex-col.space-y-1.pt-4
      - @left_items.each do |item|
        = item

  - if @right_items.present?
    %ul.flex.flex-col.space-y-1.pt-4
      - @right_items.each do |item|
        = item

  %button.absolute.top-4.right-4.inline-flex.items-center.justify-center.rounded-md.p-2.text-zinc-50.transition-colors.hover:bg-zinc-800.hover:text-zinc-50.focus:outline-none.focus-visible:ring-2.focus-visible:ring-zinc-400.focus-visible:ring-offset-2.focus-visible:ring-offset-zinc-950#mobile-menu-close-button{ role: :button }
    ⨯

:javascript
  (() => {
    const root = document.documentElement;
    const MENU_HIDDEN_CLASS = 'hidden';
    const MENU_OFFSCREEN_CLASS = '-translate-x-full';
    const ROOT_LOCK_CLASS = 'overflow-hidden';

    const closeMenu = (menu, { hideImmediately = false } = {}) => {
      if (!menu) {
        root.classList.remove(ROOT_LOCK_CLASS);
        return;
      }

      menu.classList.add(MENU_OFFSCREEN_CLASS);
      root.classList.remove(ROOT_LOCK_CLASS);

      if (hideImmediately) {
        menu.classList.add(MENU_HIDDEN_CLASS);
        return;
      }

      menu.addEventListener(
        'transitionend',
        () => menu.classList.add(MENU_HIDDEN_CLASS),
        { once: true }
      );
    };

    const openMenu = (menu) => {
      if (!menu) return;

      menu.classList.remove(MENU_HIDDEN_CLASS);
      requestAnimationFrame(() => {
        menu.classList.remove(MENU_OFFSCREEN_CLASS);
        root.classList.add(ROOT_LOCK_CLASS);
      });
    };

    const bindNavbar = () => {
      const button = document.getElementById('mobile-menu-button');
      const closeButton = document.getElementById('mobile-menu-close-button');
      const menu = document.getElementById('mobile-menu');

      if (!button || !closeButton || !menu || button.dataset.navbarBound === 'true') {
        return;
      }

      button.dataset.navbarBound = 'true';

      const toggleMenu = () => {
        if (menu.classList.contains(MENU_HIDDEN_CLASS)) {
          openMenu(menu);
          return;
        }

        closeMenu(menu);
      };

      button.addEventListener('click', toggleMenu);
      closeButton.addEventListener('click', () => closeMenu(menu));
      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => closeMenu(menu, { hideImmediately: true }));
      });
    };

    if (window.__tramwayNavbarGlobalBound !== true) {
      window.__tramwayNavbarGlobalBound = true;

      document.addEventListener('turbo:before-cache', () => {
        closeMenu(document.getElementById('mobile-menu'), { hideImmediately: true });
      });

      document.addEventListener('turbo:load', () => {
        const menu = document.getElementById('mobile-menu');
        bindNavbar();

        if (!menu || menu.classList.contains(MENU_HIDDEN_CLASS)) {
          root.classList.remove(ROOT_LOCK_CLASS);
        }
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth >= 640) {
          closeMenu(document.getElementById('mobile-menu'), { hideImmediately: true });
        }
      });
    }

    bindNavbar();
  })();
